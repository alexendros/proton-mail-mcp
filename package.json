{
  "name": "proton-mail-mcp",
  "version": "0.1.0",
  "description": "MCP server for Proton Mail via Proton Mail Bridge (IMAP/SMTP). Dual transport: stdio + streamable HTTP.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "proton-mail-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "imapflow": "^1.0.189",
    "mailparser": "^3.7.2",
    "nodemailer": "^8.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
