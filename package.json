{
  "name": "proton-mail-mcp",
  "version": "0.1.0",
  "description": "MCP server for Proton Mail via Proton Mail Bridge (IMAP/SMTP). Dual transport: stdio + streamable HTTP.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "proton-mail-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.0",
    "express": "^4.21.2",
    "imapflow": "^1.0.189",
    "mailparser": "^3.7.2",
    "nodemailer": "^6.9.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
